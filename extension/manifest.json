{
  "manifest_version": 3,
  "name": "Save to Recipease",
  "version": "1.0.0",
  "description": "Save recipes from any website to Recipease",
  "permissions": ["scripting", "contextMenus", "storage"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
"action": {
    "default_title": "Save to Recipease"
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
